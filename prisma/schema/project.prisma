model Project {
  id          String @id @default(cuid())
  name        String
  description String

  specification Json @default("{}")

  contexts Context[]

  dbmodel    Json
  gantttasks GanttTasks[]

  thoughts           ProjectThought[]
  writings           ProjectWriting[]
  projectGantdomains ProjectGantdomains[]

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model ProjectGantdomains {
  id          String @id @default(cuid())
  name        String
  description String

  tasks     GanttTasks[]
  projectId String
  project   Project      @relation(fields: [projectId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GanttTasks {
  id          String @id @default(cuid())
  name        String
  description String
  pageData    Json
  position    Int    @default(0)
  categoryId  String

  projectGantdomains   ProjectGantdomains @relation(fields: [projectGantdomainsId], references: [id])
  projectGantdomainsId String

  ganttcolumnType  GanttColumnType @default(PLANNED)

  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  writing   ProjectWriting?

  category  Category @relation(fields: [categoryId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GanttColumnType {
  PLANNED
  IN_PROGRESS
  DONE
}

model Category {
  id   String @id @default(cuid())
  name String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  gantttasks GanttTasks[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model ProjectWriting {
  id      String   @id @default(cuid())
  title   String
  content Json
  stamped DateTime @default(now())

  ganttTaskId String?    @unique
  ganttTask   GanttTasks? @relation(fields: [ganttTaskId], references: [id])

  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectThought {
  id String @id @default(cuid())

  title   String
  content Json
  stamped DateTime @default(now())

  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
