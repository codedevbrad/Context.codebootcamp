model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String

  contexts Context[]
  contextGroups ContextGroup[]
  projects Project[]
  projectThoughts ProjectThought[]
  projectWritings ProjectWriting[]
  categories Category[]
  projectGantdomains ProjectGantdomains[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}